  "policyPacks": {
    "relaxed": {
      "label": "Relaxed",
      "description": "Block known tracker/adtech candidates for high-risk execution types and strip their cookies.",
      "blockKnownTrackers": [
        "script",
        "xmlhttprequest",
        "sub_frame",
        "cookie"
      ]
    },
    "balanced": {
      "label": "Balanced",
      "description": "Relaxed plus all third-party frames.",
      "blockKnownTrackers": [
        "script",
        "xmlhttprequest",
        "sub_frame",
        "cookie"
      ],
      "blockThirdParty": [
        "sub_frame"
      ]
    },
    "strict": {
      "label": "Strict",
      "description": "Block third-party scripts, XHR and frames; strip third-party cookies. Keep images/CSS/fonts/media alone.",
      "blockThirdParty": [
        "script",
        "xmlhttprequest",
        "sub_frame",
        "cookie"
      ]
    },
    "toxic-web": {
      "label": "Toxic web",
      "description": "Aggressive test mode: block third-party scripts, XHR, frames and cookies plus tracker images.",
      "blockThirdParty": [
        "script",
        "xmlhttprequest",
        "sub_frame",
        "cookie"
      ],
      "blockKnownTrackers": [
        "script",
        "xmlhttprequest",
        "sub_frame",
        "image",
        "cookie"
      ]
    }
  }
